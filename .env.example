# Backblaze B2 (required)
B2_ENDPOINT=your_b2_endpoint
B2_REGION=your_b2_region
B2_KEY_ID=your_key_id
B2_APPLICATION_KEY=your_application_key
B2_BUCKET_NAME=your-bucket-name

# Example of what filled-in values look like (fake — for visual reference only):
# B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# B2_REGION=us-west-004
# B2_KEY_ID=00abcdef1234567000000001
# B2_APPLICATION_KEY=K001AbCdEfGhIjKlMnOpQrStUvWxYz0=
# B2_BUCKET_NAME=my-app-uploads

# OpenAI (required) — the same key drives (1) live transcription via the
# GPT-Realtime-Whisper Realtime API, (2) the LLM-backed `pii` redaction
# layer via chat completions, and (3) the dashboard's "AI service
# reachable" health probe.
OPENAI_API_KEY=your_openai_api_key

# Optional: realtime model override. Default targets the
# GPT-Realtime-Whisper transcription preset.
# OPENAI_REALTIME_MODEL=gpt-realtime-whisper

# Optional: which redaction detectors run by default on /record.
# Comma-separated subset of {pii, secrets, glossary}. UI lets the user
# toggle per session.
# REDACTION_DEFAULT_MODES=pii,secrets,glossary

# Optional: the `pii` layer is LLM-backed because transcribed speech
# renders PII as natural language (names, "john at example dot com",
# spelled-out numbers) that regex cannot match. These tune that call;
# `secrets` and `glossary` stay deterministic regex and need no config.
# REDACTION_PII_MODEL=gpt-4o-mini
# REDACTION_PII_TIMEOUT_S=15

# Optional: REST base for the chat-completions call above. Override only
# for an OpenAI-compatible gateway / proxy.
# OPENAI_API_BASE=https://api.openai.com/v1

# Storage default. When true (v1 default — convenient for dev testing),
# /record writes raw audio AND the unredacted transcript alongside the
# redacted bundle. When false, only the redacted transcript + manifest +
# audit trail are written (privacy default — flip this in production).
# Per-session toggles on /record override this default either way.
# v1 default: true (convenient for dev testing). Flip to false in production —
# see the Production Configuration callout in README.md.
SESSION_STORE_ORIGINALS_DEFAULT=true

# Optional: comma-separated list of allowed CORS origins for the API.
# Default (matches services/api/app/config/settings.py):
#   http://localhost:3000,http://localhost:3001
# Override with the exact frontend origin(s) in production deploys.
# API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional: dev-only escape hatch — a regex matching additional allowed
# CORS origins. Empty by default (the explicit API_CORS_ORIGINS list is
# used alone). Set to e.g. `^http://localhost:\d+$` to accept any
# localhost port without listing each. NEVER ship this to production.
# API_CORS_ORIGIN_REGEX=

# Optional: uvicorn bind port for the FastAPI backend. Default 8000.
# `pnpm dev` auto-picks the next free port if this one is busy.
# API_PORT=8000

# Optional: public base URL for the B2 bucket — when set, `repo/b2_client.py`
# builds direct public URLs instead of presigned ones for the bucket
# explorer. Leave empty (default) to always presign. Example:
#   B2_PUBLIC_URL=https://your-bucket.s3.us-west-004.backblazeb2.com
# B2_PUBLIC_URL=

# Optional: path to the JSON file holding the durable download counter
# surfaced on the dashboard. Default matches services/api/app/config/settings.py.
# Point at a persistent volume in production if you want it to survive
# container restarts.
# DOWNLOAD_COUNT_FILE=data/download_count.json

# Optional: OpenAI Realtime WebSocket base URL. Default matches the
# upstream production endpoint; override only for testing against a
# mock / staging Realtime gateway.
# OPENAI_REALTIME_URL=wss://api.openai.com/v1/realtime
